{
  "name": "flowboard",
  "version": "0.0.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "flowboard",
      "version": "0.0.0",
      "workspaces": [
        "apps/*",
        "packages/*",
        "infra",
        "e2e"
      ],
      "devDependencies": {
        "typescript": "^5.9.3"
      },
      "engines": {
        "node": ">=20"
      }
    },
    "apps/server": {
      "name": "@flowboard/server",
      "version": "0.0.0"
    },
    "apps/web": {
      "name": "@flowboard/web",
      "version": "0.0.0"
    },
    "e2e": {
      "name": "@flowboard/e2e",
      "version": "0.0.0"
    },
    "infra": {
      "name": "@flowboard/infra",
      "version": "0.0.0"
    },
    "node_modules/@flowboard/e2e": {
      "resolved": "e2e",
      "link": true
    },
    "node_modules/@flowboard/infra": {
      "resolved": "infra",
      "link": true
    },
    "node_modules/@flowboard/server": {
      "resolved": "apps/server",
      "link": true
    },
    "node_modules/@flowboard/shared": {
      "resolved": "packages/shared",
      "link": true
    },
    "node_modules/@flowboard/web": {
      "resolved": "apps/web",
      "link": true
    },
    "node_modules/typescript": {
      "version": "5.9.3",
      "resolved": "https://registry.npmjs.org/typescript/-/typescript-5.9.3.tgz",
      "integrity": "sha512-jl1vZzPDinLr9eUt3J/t7V6FgNEw9QjvBPdysz9KfQDD41fQrC2Y4vKQdiaUpFT4bXlb1RHhLpp8wtm6M5TgSw==",
      "dev": true,
      "license": "Apache-2.0",
      "bin": {
        "tsc": "bin/tsc",
        "tsserver": "bin/tsserver"
      },
      "engines": {
        "node": ">=14.17"
      }
    },
    "packages/shared": {
      "name": "@flowboard/shared",
      "version": "0.0.0"
    }
  }
}
